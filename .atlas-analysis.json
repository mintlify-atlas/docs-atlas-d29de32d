  "keyFeatures": [
    "Git-native agent definitions — every agent is a versioned git repository",
    "Framework-agnostic export to Claude Code, OpenAI, CrewAI, OpenClaw, Nanobot, Lyzr, and GitHub Models",
    "CLI tooling: init, validate, export, import, run, audit, and skills management",
    "First-class financial regulatory compliance (FINRA, Federal Reserve, SEC, CFPB)",
    "Composable agents with inheritance, dependencies, and sub-agent delegation",
    "Skills system with registry search, install, and discovery (agentskills.io compatible)",
    "Human-in-the-loop and Segregation of Duties enforcement",
    "Git caching for fast repeated runs from remote repos"
  ],
  "publicApiSurface": [
    "gitagent init [--template minimal|standard|full] [--dir]",
    "gitagent validate [--dir] [--compliance]",
    "gitagent info [--dir]",
    "gitagent export --format <system-prompt|claude-code|openai|crewai|openclaw|nanobot|lyzr|github> [--dir] [--output]",
    "gitagent import --from <claude|cursor|crewai> <path> [--dir]",
    "gitagent install [--dir]",
    "gitagent run [--repo|--dir] [--adapter] [--branch] [--prompt]",
    "gitagent audit [--dir]",
    "gitagent skills search|install|list|info",
    "gitagent lyzr create|update|info|run"
  ]
}
